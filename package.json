{
  "name": "career-ops-cloud",
  "private": true,
  "version": "0.1.0",
  "description": "Cloud version of career-ops — Railway + Supabase + Gemini.",
  "type": "module",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' --filter './apps/*' build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "dev:api": "pnpm --filter @career-ops/api dev",
    "dev:web": "pnpm --filter @career-ops/web dev",
    "dev:workers": "pnpm --filter @career-ops/workers dev",
    "db:generate": "pnpm --filter @career-ops/db generate",
    "db:migrate": "pnpm --filter @career-ops/db migrate",
    "migrate:from-md": "tsx scripts/migrate-from-md.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@career-ops/db": "workspace:*",
    "@career-ops/shared": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "playwright": "^1.60.0",
    "postgres": "^3.4.5",
    "yaml": "^2.5.1"
  }
}
