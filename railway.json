{
  "$schema": "https://railway.app/railway.schema.json",
  "services": [
    {
      "name": "api",
      "build": { "builder": "DOCKERFILE", "dockerfilePath": "docker/api.Dockerfile" },
      "deploy": {
        "startCommand": "node apps/api/dist/index.js",
        "healthcheckPath": "/health",
        "restartPolicyType": "ON_FAILURE"
      }
    },
    {
      "name": "web",
      "build": { "builder": "DOCKERFILE", "dockerfilePath": "docker/web.Dockerfile" },
      "deploy": {
        "startCommand": "node apps/web/server.js",
        "restartPolicyType": "ON_FAILURE"
      }
    },
    {
      "name": "worker-evaluator",
      "build": { "builder": "DOCKERFILE", "dockerfilePath": "docker/workers.Dockerfile" },
      "deploy": {
        "startCommand": "node apps/workers/dist/evaluator.js",
        "restartPolicyType": "ON_FAILURE"
      }
    },
    {
      "name": "worker-pdfgen",
      "build": { "builder": "DOCKERFILE", "dockerfilePath": "docker/workers.Dockerfile" },
      "deploy": {
        "startCommand": "node apps/workers/dist/pdfgen.js",
        "restartPolicyType": "ON_FAILURE"
      }
    },
    {
      "name": "worker-interview-prep",
      "build": { "builder": "DOCKERFILE", "dockerfilePath": "docker/workers.Dockerfile" },
      "deploy": {
        "startCommand": "node apps/workers/dist/interview-prep.js",
        "restartPolicyType": "ON_FAILURE"
      }
    },
    {
      "name": "worker-tailor-cv",
      "build": { "builder": "DOCKERFILE", "dockerfilePath": "docker/workers.Dockerfile" },
      "deploy": {
        "startCommand": "node apps/workers/dist/tailor-cv.js",
        "restartPolicyType": "ON_FAILURE"
      }
    },
    {
      "name": "worker-scheduler",
      "build": { "builder": "DOCKERFILE", "dockerfilePath": "docker/workers.Dockerfile" },
      "deploy": {
        "startCommand": "node apps/workers/dist/scheduler.js",
        "restartPolicyType": "ON_FAILURE"
      }
    },
    {
      "name": "worker-liveness",
      "build": { "builder": "DOCKERFILE", "dockerfilePath": "docker/workers.Dockerfile" },
      "deploy": {
        "startCommand": "node apps/workers/dist/liveness.js",
        "cronSchedule": "0 9 * * *",
        "restartPolicyType": "NEVER"
      }
    }
  ]
}
