# ── Supabase ──────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Database (direct Postgres connection for workers/migrations) ──
# Use the pooler (port 6543) for serverless/short-lived. Use direct (5432) for migrations.
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
DATABASE_URL_POOLER=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── Gemini ────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_FLASH=gemini-2.5-flash

# ── Storage ───────────────────────────────────────────────
STORAGE_BUCKET=career-ops

# ── Single-tenant fallback ────────────────────────────────
# UUID of the default user while signup is closed.
# Generate one: select gen_random_uuid();
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000000

# ── API ───────────────────────────────────────────────────
API_PORT=3001
API_PUBLIC_URL=https://api.career-ops.local

# ── Web ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=${SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${SUPABASE_ANON_KEY}

# ── Jobs (pg-boss uses DATABASE_URL) ──────────────────────
JOBS_SCHEMA=pgboss

# ── Migration source (path to legacy career-ops repo) ─────
LEGACY_REPO_PATH=../career-ops
